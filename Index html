<script>
function tambah(angka){
document.getElementById("hasil").value += angka;
}

function hapus(){
document.getElementById("hasil").value="";
}

function hitung(){
try{
document.getElementById("hasil").value=
eval(document.getElementById("hasil").value);
}
catch{
alert("Input salah");
}
}
</script>

</body>
</html>
